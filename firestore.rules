rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read if authenticated (needed for referral lists), write own doc only
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Dogs: read if authenticated, write if owner
    match /dogs/{dogId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // SwapRequests: read/write if participant
    match /swapRequests/{swapId} {
      allow read: if request.auth != null
        && (resource.data.requesterId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.requesterId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.requesterId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
      allow delete: if false;
    }

    // Conversations: read/write if participant
    match /conversations/{convId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      // Messages: read/write if conversation participant.
      // Allow senderId == 'swapdog-team' for system welcome messages written
      // by an authenticated participant on behalf of the system account.
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
          && (
            request.resource.data.senderId == request.auth.uid
            || request.resource.data.senderId == 'swapdog-team'
          );
        allow update: if false;
        allow delete: if false;
      }
    }

    // Reviews: read if authenticated, create only (immutable)
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.reviewerId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // Referral codes:
    //   - Any authenticated user can read (to validate a code at sign-up)
    //   - Code creator can create their own code documents
    //   - Code creator can update anything on their code
    //   - Any authenticated user can redeem a code (increment usedCount / usedBy),
    //     but the immutable fields (code, createdBy, isActive, maxUses) must not change
    match /referral_codes/{codeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null
        && (
          // Code creator can update anything (e.g. deactivate)
          resource.data.createdBy == request.auth.uid
          // Any authenticated user can redeem: only usedCount and usedBy may change
          || (
            request.resource.data.code       == resource.data.code
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.isActive  == resource.data.isActive
            && request.resource.data.maxUses   == resource.data.maxUses
          )
        );
      allow delete: if false;
    }
  }
}
