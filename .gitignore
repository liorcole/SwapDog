# ── Xcode generated ────────────────────────────────────────────────────────────
# The .xcodeproj is generated by XcodeGen from project.yml; don't commit it.
*.xcodeproj/
!*.xcodeproj/project.pbxproj   # keep if you ever commit the project manually
*.xcworkspace/
xcuserdata/
DerivedData/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint

# ── Swift Package Manager ──────────────────────────────────────────────────────
.build/
.swiftpm/
Package.resolved

# ── Firebase ───────────────────────────────────────────────────────────────────
# Never commit GoogleService-Info.plist — it contains API keys
GoogleService-Info.plist

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Tooling ────────────────────────────────────────────────────────────────────
*.log
*.orig
*.rej
