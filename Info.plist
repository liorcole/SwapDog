<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- MARK: - Privacy Permission Strings -->

	<!-- Camera: used when the user adds or updates a dog photo or profile picture. -->
	<key>NSCameraUsageDescription</key>
	<string>SwapDog uses your camera to take photos of your dog for your profile.</string>

	<!-- Photo Library: used when the user selects existing photos for a dog or profile. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SwapDog accesses your photo library so you can add pictures of your dog to your profile.</string>

	<!-- Location: used to show nearby dog owners in the Discovery feed. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SwapDog uses your location to find nearby dog owners available for swapping.</string>

	<!-- MARK: - Push Notifications -->
	<!-- FCM requires the remote-notifications background mode. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- MARK: - App Transport Security -->
	<!-- Allows HTTPS connections to Firebase and App Store services. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>

	<!-- MARK: - Supported Interface Orientations (iPhone) -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- MARK: - Supported Interface Orientations (iPad) -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- MARK: - Launch Screen -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>

	<!-- MARK: - Bundle Metadata -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>SwapDog</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- MARK: - App Icon -->
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
</dict>
</plist>
